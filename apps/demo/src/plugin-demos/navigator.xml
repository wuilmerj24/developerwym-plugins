<Page xmlns="http://schemas.nativescript.org/tns.xsd" navigatingTo="navigatingTo" class="page">
    <Page.actionBar>
        <ActionBar title="navigator" icon="" class="action-bar">
        </ActionBar>
    </Page.actionBar>
    <StackLayout class="p-20">
        <ScrollView class="h-full">
          <StackLayout>
            <Button text="Open GMaps" tap="{{ openG }}" class="btn btn-primary"/>
            <Button text="Open Waze" tap="{{ openW }}" class="btn btn-primary"/>
            <Button text="Open Badium" tap="{{ openB }}" class="btn btn-primary"/>
            <Button text="Open Apple" tap="{{ openA }}" class="btn btn-primary"/>

          </StackLayout>
        </ScrollView>
    </StackLayout>
</Page>